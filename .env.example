# ----------------------------------------------------------------------------
# 1776 CrossFit Surmount Challenge Tracker — Environment Variables
# Copy this file to ".env.local" for local development and fill in real values.
# In production (Vercel) set these in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# --- NextAuth.js ---
# A random secret used to encrypt session tokens.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# The full canonical URL of your app.
# Local:       http://localhost:3000
# Production:  https://your-app.vercel.app  (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (from Google Cloud Console → Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Supabase ---
# Project Settings → API
# URL and anon key are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service role key is SECRET. It bypasses Row Level Security and must
# only ever be used on the server. Never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
